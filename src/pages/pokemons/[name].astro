---
import type { GetStaticPaths } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import PokemonCard from "@components/pokemons/PokemonCard.astro";

import type { PokemonListResponse } from "@interfaces/pokemon-list.response";

const { name } = Astro.params as { name: string };

export const getStaticPaths = (async () => {
  const resp = await fetch("https://pokeapi.co/api/v2/pokemon?limit=151");
  const { results } = (await resp.json()) as PokemonListResponse;

  const staticPaths = results.map((pokemon) => ({
    params: {
      name: pokemon.name,
    },
    props: {
      name: pokemon.name,
      url: pokemon.url,
    },
  }));

  return staticPaths;
}) satisfies GetStaticPaths;

const { url } = Astro.props as { url: string };

const id = url.split("/").filter(Boolean).pop() as string;
const audioSrc = `https://raw.githubusercontent.com/PokeAPI/cries/main/cries/pokemon/latest/${id}.ogg`;
const imageSrc = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;

const title = `Pokemon static | #${id} ${name}`;
const description = `Detalles del pokemon ${name}`;
---

<MainLayout title={title} description={description} image={imageSrc}>
  <section class="mt-10 m-auto flex flex-col justify-center items-center">
    <div transition:animate="slide" class="w-full">
      <a href="/" class="rounded">Regresar</a>
      <h1 class="text-5xl capitalize text-center">{name}</h1>
    </div>

    <PokemonCard name={name} url={url} isBig />

    <audio controls transition:animate="slide">
      <source src={audioSrc} type="audio/ogg" />
      Your browser does not support the audio element.
    </audio>
  </section>
</MainLayout>

<style>
  a {
    color: #ffffff;
    padding: 0.5rem;
    background-color: #3b82f6;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
