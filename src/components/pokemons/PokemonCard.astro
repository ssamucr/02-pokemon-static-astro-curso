---
interface Props {
    name: string;
    url: string;
}

const { name, url } = Astro.props as Props;

const id = url.split("/").filter(Boolean).pop() as string;

const imageSrc = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;

---

<a
    href={`/pokemons/${name}`}
    id={name}
    class="bg-slate-700 rounded flex flex-col justify-center items-center p-2 hover:bg-slate-600 transition-colors cursor-pointer"
>
  <img
    src={imageSrc}
    alt={name}
  />
  <span class="capitalize">{name}</span>
</a>
